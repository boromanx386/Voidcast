{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.voidcast.app",
  "productName": "Voidcast",
  "asar": true,
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist-electron",
    "dist"
  ],
  "extraResources": [
    {
      "from": "../tts-server",
      "to": "tts-server",
      "filter": [
        "tools_main.py",
        "main.py",
        "scrape_tool.py",
        "youtube_tools.py",
        "requirements-tools.txt",
        "requirements.txt",
        "web-ui/**"
      ]
    }
  ],
  "win": {
    "icon": "public/favicon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}_${version}_Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "shortcutName": "Voidcast"
  },
  "publish": {
    "provider": "github",
    "owner": "boromanx386",
    "repo": "Voidcast",
    "releaseType": "release"
  }
}
